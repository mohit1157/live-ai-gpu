# Raspberry Pi Deployment Configuration

# Your Pi's IP address on local network
PI_IP=192.168.1.100

# Database password
DB_PASSWORD=postgres

# JWT secret (shared between NextAuth and FastAPI)
JWT_SECRET=your-secret-key-change-in-production

# Claude API key (get from https://console.anthropic.com)
CLAUDE_API_KEY=sk-ant-xxxxx

# ============================================
# RunPod GPU Service URLs
# After deploying GPU services to RunPod,
# update these with your RunPod pod URLs
# ============================================
AVATAR_SERVICE_URL=https://your-runpod-id-8001.proxy.runpod.net
VOICE_SERVICE_URL=https://your-runpod-id-8002.proxy.runpod.net
EXPRESSION_SERVICE_URL=https://your-runpod-id-8003.proxy.runpod.net
STREAMING_SERVICE_URL=https://your-runpod-id-8004.proxy.runpod.net
